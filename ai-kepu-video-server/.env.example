# .env 文件示例
# 复制此文件为 .env 并填入真实配置。不要提交 .env。

# LLM 配置
LLM_PROTOCOL=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-sonnet-4-5

# 豆包 TTS 配置
DOUBAO_TTS_API_URL=https://openspeech.bytedance.com/api/v1/tts
DOUBAO_TTS_APPID=
DOUBAO_TTS_TOKEN=
DOUBAO_TTS_CLUSTER=volcano_tts
DOUBAO_TTS_DEFAULT_VOICE=zh_male_jieshuoxiaoming_moon_bigtts

# 图像生成配置
SEEDREAM_API_URL=https://api.openai.com/v1/images/generations
SEEDREAM_API_KEY=
SEEDREAM_MODEL=gpt-image-1
SEEDREAM_SIZE=auto

# 腾讯云 COS 配置（可选）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_BUCKET_DIR=kepu
COS_CDN_DOMAIN=

# MySQL 配置（仅 USE_REMOTE_DB=1 时需要；默认本地 SQLite）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ai_kepu

# Redis 配置（仅 USE_REMOTE_DB=1 时需要；默认本地内存缓存）
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
